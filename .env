########################################
# 🔐 CORE APPLICATION SETTINGS
########################################
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=replace_with_strong_random_secret
APP_HOST=0.0.0.0
APP_PORT=5000

########################################
# 🚀 API KEYS (NEVER COMMIT REAL VALUES)
########################################
NASA_API_KEY=your_nasa_api_key_here
EARTHDATA_USERNAME=your_earthdata_username
EARTHDATA_PASSWORD=your_earthdata_password

OPENAI_API_KEY=your_openai_api_key_here

########################################
# 🌍 DATA SOURCES CONFIG
########################################
NASA_DATASET=EMIT
NASA_API_BASE=https://api.nasa.gov
EARTHDATA_BASE=https://earthdata.nasa.gov

# Optional additional satellite sources
MODIS_ENABLED=true
SENTINEL_ENABLED=true
LANDSAT_ENABLED=true

########################################
# 🧠 AI / PROCESSING SETTINGS
########################################
MODEL_MODE=analysis
SPECTRAL_ANALYSIS_ENABLED=true
FFT_ENABLED=true
MINERAL_MODEL_VERSION=v2

# Threshold tuning
GOLD_DETECTION_THRESHOLD=0.75
DIAMOND_DETECTION_THRESHOLD=0.60

########################################
# ⚙️ PERFORMANCE / PROCESSING
########################################
MAX_WORKERS=4
REQUEST_TIMEOUT=30
CACHE_ENABLED=true
CACHE_TTL=300

########################################
# 🗂️ STORAGE SETTINGS
########################################
DATA_DIR=./data
CACHE_DIR=./cache
LOG_DIR=./logs

########################################
# 📊 LOGGING
########################################
LOG_LEVEL=INFO
LOG_FILE=omniscanner.log

########################################
# 🔐 SECURITY SETTINGS
########################################
CORS_ALLOWED_ORIGINS=*
RATE_LIMIT_ENABLED=true
RATE_LIMIT=100/hour

########################################
# 🧪 TEST / CI SETTINGS
########################################
TEST_MODE=false
MOCK_NASA=false

########################################
# ☁️ DEPLOYMENT (OPTIONAL)
########################################
ENVIRONMENT=production
USE_DOCKER=true
GUNICORN_WORKERS=3
