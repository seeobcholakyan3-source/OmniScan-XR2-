# ==========================================================
# OmniScan-XR2 Environment Configuration
# ==========================================================

# -------------------------------
# APP CONFIG
# -------------------------------
APP_ENV=development
DEBUG=True
HOST=0.0.0.0
PORT=5001

# -------------------------------
# SECURITY
# -------------------------------
SECRET_KEY=change-this-to-a-long-random-string
ALLOWED_ORIGINS=*

# -------------------------------
# NASA / EARTHDATA CONFIG
# -------------------------------
# Get from: https://urs.earthdata.nasa.gov
NASA_EARTHDATA_USER=your_earthdata_username
NASA_EARTHDATA_PASSWORD=your_earthdata_password

# Optional API-style key (if used in your GitHub secrets)
NASA_API_KEY=your_nasa_api_key

# Base endpoints (can be swapped if APIs change)
NASA_CMR_URL=https://cmr.earthdata.nasa.gov/search/granules.json
NASA_GIBS_URL=https://gibs.earthdata.nasa.gov

# -------------------------------
# SATELLITE INGESTION SETTINGS
# -------------------------------
SATELLITE_SOURCE=NASA
SATELLITE_TIMEOUT=10
SATELLITE_CACHE_TTL=300

# -------------------------------
# AI / MODEL CONFIG
# -------------------------------
MODEL_TYPE=isolation_forest
MODEL_CONTAMINATION=0.15
MODEL_RANDOM_STATE=42

# -------------------------------
# DATABASE (FUTURE USE)
# -------------------------------
DATABASE_URL=sqlite:///omniscanner.db

# -------------------------------
# LOGGING
# -------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/omniscanner.log

# -------------------------------
# PERFORMANCE
# -------------------------------
MAX_REQUESTS_PER_MINUTE=60
WORKERS=2

# -------------------------------
# FEATURE FLAGS
# -------------------------------
ENABLE_REAL_SATELLITE=true
ENABLE_AI_ANALYSIS=true
ENABLE_CACHE=false

# -------------------------------
# EXPORT SETTINGS
# -------------------------------
EXPORT_MESH_FORMAT=obj
EXPORT_ENABLE_VERTEX_COLOR=true

# -------------------------------
# DEV / DEBUG FLAGS
# -------------------------------
MOCK_SATELLITE_DATA=false
VERBOSE_LOGGING=true
