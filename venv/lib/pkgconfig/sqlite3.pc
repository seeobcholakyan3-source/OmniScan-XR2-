# Package Information for pkg-config

prefix=/workspaces/OmniScan-XR2/venv
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: SQLite
Description: SQL database engine
Version: 3.53.0
Libs: -L${libdir} -lsqlite3
Libs.private: -lm -lz -ldl -lpthread -L/workspaces/OmniScan-XR2/venv/lib -licui18n -licuuc -licudata
Cflags: -I${includedir}
